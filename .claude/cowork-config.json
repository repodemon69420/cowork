{
  "version": "1.0.0",
  "orchestrator": {
    "enabled": true,
    "maxIterations": 10,
    "idleCheckLimit": 3,
    "idleWaitSeconds": 120,
    "branchPrefix": "claude/iter-",
    "keepBranches": 3
  },
  "killSwitch": {
    "type": "github-issue",
    "issueNumber": 1,
    "fallbackFile": "TASKS.md",
    "fallbackStatus": "Status: OFF"
  },
  "agents": {
    "worker": {
      "enabled": true,
      "maxParallel": 4,
      "timeout": 3600
    },
    "qa": {
      "enabled": true,
      "runAfterEachTask": true,
      "minCoverage": 80,
      "criticalOnly": false
    },
    "reviewer": {
      "enabled": true,
      "maxFixCycles": 3,
      "requireApproval": true
    },
    "reporter": {
      "enabled": true,
      "updateFile": "MORNING_REPORT.md"
    },
    "productMind": {
      "enabled": true,
      "minTasksToGenerate": 3,
      "maxTasksToGenerate": 5
    }
  },
  "git": {
    "rebaseOnPull": true,
    "autoCommit": true,
    "commitPrefix": "feat: [cowork]",
    "pushToOrigin": true
  },
  "files": {
    "taskQueue": "TASKS.md",
    "morningReport": "MORNING_REPORT.md",
    "qaReport": "QA_REPORT.md",
    "logDirectory": "logs/",
    "agentsDirectory": ".claude/agents/"
  },
  "logging": {
    "level": "info",
    "file": "logs/cowork.log",
    "maxSize": "10M",
    "maxFiles": 5
  }
}
